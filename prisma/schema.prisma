generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id             Int      @id @default(autoincrement())
  name           String
  email          String
  phone          String?
  message        String?
  domainInterest String?
  offer          String?
  subject        String?
  source         String?
  formType       String
  createdAt      DateTime @default(now())
}
